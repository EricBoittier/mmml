configfile: "config.yaml"

import os
import sys
from pathlib import Path


def _repo_python() -> str:
    repo = Path(workflow.basedir).resolve().parents[1]
    env_py = os.environ.get("MMML_PYTHON", "").strip()
    if env_py:
        return env_py
    venv = repo / ".venv" / "bin" / "python"
    if venv.is_file():
        return str(venv)
    conda_prefix = os.environ.get("CONDA_PREFIX", "").strip()
    if conda_prefix:
        conda_py = Path(conda_prefix) / "bin" / "python"
        if conda_py.is_file():
            return str(conda_py)
    return "python3"


_REPO_ROOT = Path(workflow.basedir).resolve().parents[1]
_OUTPUT_ROOT = str(config.get("output_root", "artifacts/pbc_solvent_burst"))
_ARTIFACT_ROOT = f"../../{_OUTPUT_ROOT}"

_SCRIPTS = Path(workflow.basedir) / "scripts"
if str(_SCRIPTS) not in sys.path:
    sys.path.insert(0, str(_SCRIPTS))
from campaign_lib import (  # noqa: E402
    cell_from_tag,
    cell_run_tag,
    cell_slurm_tier,
    iter_matrix_cells,
    slurm_nodelist_for_tier,
    slurm_tier_enabled,
)

_MATRIX = list(iter_matrix_cells(dict(config)))
_CFG = dict(config)
_CELL_TAGS = [cell_run_tag(c, _CFG) for c in _MATRIX]
_TIER_ENABLED = slurm_tier_enabled(_CFG)


def _artifact_dir(wildcards) -> str:
    return str(_REPO_ROOT / _OUTPUT_ROOT / wildcards.tag)


def _burst_tier(wildcards) -> str:
    cell = cell_from_tag(_CFG, wildcards.tag)
    return cell_slurm_tier(cell, _CFG)


def _sched_gpu_fast(wildcards) -> int:
    if not _TIER_ENABLED:
        return 1
    return 0 if _burst_tier(wildcards) == "slow" else 1


def _sched_gpu_slow(wildcards) -> int:
    if not _TIER_ENABLED:
        return 0
    return 1 if _burst_tier(wildcards) == "slow" else 0


def _slurm_extra(wildcards) -> str:
    mail = str(config.get("slurm_mail_user", "ericdavid.boittier@unibas.ch"))
    if _TIER_ENABLED:
        nodelist = slurm_nodelist_for_tier(_CFG, _burst_tier(wildcards))
    else:
        nodelist = slurm_nodelist_for_tier(_CFG, "fast")
    if nodelist:
        return f"--mail-user={mail} --mail-type=END,FAIL --nodelist={nodelist}"
    return f"--mail-user={mail} --mail-type=END,FAIL"


rule all:
    input:
        expand(
            "{root}/{tag}/done.txt",
            root=_ARTIFACT_ROOT,
            tag=_CELL_TAGS,
        ),


rule run_burst:
    output:
        touch("{root}/{tag}/done.txt"),
    log:
        stdout="{root}/{tag}/stdout.log",
    params:
        out_dir=_artifact_dir,
        workflow_dir=workflow.basedir,
    resources:
        gpu=1,
        gpu_fast=_sched_gpu_fast,
        gpu_slow=_sched_gpu_slow,
        charmm_slot=1,
        runtime=int(config.get("slurm_runtime_min", 2880)),
        mem_mb_per_cpu=int(config.get("slurm_mem_mb_per_cpu", 3000)),
        tasks=int(config.get("slurm_ntasks", 1)),
        cpus_per_task=int(config.get("slurm_cpus_per_task", 4)),
        nodes=int(config.get("slurm_nodes", 1)),
        slurm_partition=str(config.get("slurm_partition", "gpu")),
        slurm_extra=_slurm_extra,
    shell:
        """
        set -euo pipefail
        mkdir -p {params.out_dir}
        bash {params.workflow_dir}/scripts/job_shell.sh {wildcards.tag}
        test -s {output}
        """
