setup: pbc_npt
backend: pycharmm
composition: DCM:100
output_dir: REPLACE_OUT
box_size: REPLACE_BOX
spacing: 4.0
temperature: 300.0
pressure: 1.0
checkpoint: REPLACE_CKPT

md_stages: mini
mini_nstep: REPLACE_MINI_NSTEP
